# ── Telegram ─────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot (free tier bypass)
# Get your ID by messaging @userinfobot on Telegram
ADMIN_USER_IDS=

# ── AI Providers ──────────────────────────────────────────────────────────────
# Primary (free) — https://console.groq.com
GROQ_API_KEY=

# Fallback (free) — https://aistudio.google.com
GEMINI_API_KEY=

# Last resort (paid) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Flight Price APIs ─────────────────────────────────────────────────────────
# SerpAPI for Google Flights scraping — https://serpapi.com (free tier: 100/month)
SERPAPI_KEY=

# ── App Config ────────────────────────────────────────────────────────────────
# Where to store generated PDFs
PDF_OUTPUT_DIR=./pdfs

# Free plan limits
FREE_TASKS_PER_DAY=5
FREE_INVOICES_PER_MONTH=2
FREE_FLIGHT_WATCHES=1
